    "lr": 0.001,
    "seed": 13
  },
  "classical_projector": {
    "batch_size": 32,
    "rank": 4,
    "max_vectors": 512,
    "seed": 13
  },
  "classical_steering": {
    "batch_size": 32,
    "gain": 0.25
  },
  "quantum_projector": {
    "batch_size": 32,
    "rank": 4,
    "num_qubits": 4,
    "angle_scale": 1.25,
    "max_vectors": 512,
    "seed": 13
  },
  "quantum_steering": {
    "batch_size": 32,
    "gain": 0.25
  },
  "supervised_quantum_projector": {
    "batch_size": 32,
    "rank": 4,
