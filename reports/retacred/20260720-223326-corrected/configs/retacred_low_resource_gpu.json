    "max_train_samples": 512,
    "learning_rate": 0.03,
    "training_steps": 100,
    "layerwise": true,
    "center": true,
    "seed": 13,
    "feature_seed": 17
  },
  "supervised_quantum_steering": {
    "batch_size": 128,
    "gain": 0.1
