    "max_vectors": 4096,
    "center": true,
    "seed": 13
  },
  "quantum_steering": {
    "batch_size": 128,
    "gain": 0.25
  },
  "supervised_quantum_projector": {
    "batch_size": 128,
    "rank": 16,
    "num_qubits": 6,
    "depth": 2,
    "angle_scale": 1.0,
