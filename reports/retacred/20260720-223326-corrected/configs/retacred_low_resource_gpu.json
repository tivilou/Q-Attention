    "dropout": 0.1,
    "lr": 0.0007,
    "seed": 13
  },
  "classical_projector": {
    "batch_size": 128,
    "rank": 16,
    "max_vectors": 4096,
    "center": true,
    "seed": 13
  },
  "classical_steering": {
    "batch_size": 128,
    "gain": 0.25
  },
  "quantum_projector": {
